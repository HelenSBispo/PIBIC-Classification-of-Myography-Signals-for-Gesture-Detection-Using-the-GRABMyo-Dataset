def filtrar_passa_banda(dados, fi=FREQ_CORTE_INFERIOR,
                        fs_corte=FREQ_CORTE_SUPERIOR,
                        fq=FREQ_AMOSTRAGEM, ord=ORDEM_FILTRO):
    """Butterworth bandpass 4ª ordem — seção 2.2."""
    nyq  = 0.5 * fq
    low  = max(fi / nyq, 1e-5)
    high = min(fs_corte / nyq, 0.99999)
    if high <= low:
        return dados
    try:
        sos = scipy.signal.butter(ord, [low, high], btype='band', output='sos')
        return scipy.signal.sosfiltfilt(sos, dados, axis=0)
    except ValueError:
        return dados


def filtrar_notch(dados, f0=FREQ_NOTCH, Q=Q_NOTCH, fq=FREQ_AMOSTRAGEM):
    """[FIX-16] Notch 60 Hz — remove interferência elétrica."""
    nyq = fq / 2.0
    w0  = f0 / nyq
    if not (0.01 < w0 < 0.99):
        return dados
    try:
        b, a = scipy.signal.iirnotch(w0, Q)
        return scipy.signal.filtfilt(b, a, dados, axis=0)
    except Exception:
        return dados


def normalizar_sinal(sinal):
    """
    [FIX-17] Z-score único por segmento — seção 2.2 do artigo.
    Evita dupla normalização com StandardScaler.
    """
    media = np.mean(sinal, axis=0)
    dp    = np.std(sinal,  axis=0)
    dp[dp < 1e-7] = 1.0
    return (sinal - media) / dp


def preprocessar(emg_raw, fs_real=FREQ_AMOSTRAGEM):
    """
    Pipeline completo — seção 2.2:
    1. Butterworth bandpass (20–500 Hz, 4ª ordem)
    2. Notch 60 Hz  [FIX-16]
    3. Z-score normalization  [FIX-17]
    """
    emg = filtrar_passa_banda(emg_raw, fq=fs_real)
    emg = filtrar_notch(emg,           fq=fs_real)
    emg = normalizar_sinal(emg)
    return emg


def calcular_sens_espec(cm):
    n = cm.shape[0]
    sens  = np.zeros(n)
    espec = np.zeros(n)
    for k in range(n):
        TP = cm[k, k]
        FN = cm[k, :].sum() - TP
        FP = cm[:, k].sum() - TP
        TN = cm.sum() - (TP + FN + FP)
        sens[k]  = TP / (TP + FN) if (TP + FN) > 0 else 0.0
        espec[k] = TN / (TN + FP) if (TN + FP) > 0 else 0.0
    return sens, espec


def calcular_entropia_shannon(probs):
    probs = np.clip(probs, 1e-10, 1.0)
    with np.errstate(divide='ignore', invalid='ignore'):
        ent = scipy_entropy(probs, axis=1, base=2)
    return np.mean(ent[np.isfinite(ent)])


