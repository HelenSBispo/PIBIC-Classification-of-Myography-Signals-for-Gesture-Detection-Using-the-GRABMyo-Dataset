def gerador_dados(caminho_base, sessoes, comp_seg=COMPRIMENTO_SEGMENTO,
                  idx_emg=INDICES_CANAIS_EMG, usar_brutos=USAR_DADOS_BRUTOS,
                  verbose=True):
    """
    [FIX-9]  Label via nome do arquivo.
    [FIX-13] Lista arquivos via .hea → ignora .dat sem par .hea.
    [FIX-16] Pipeline: passa-banda + notch + Z-score.
    """
    if verbose:
        print(f"\nINFO Gerador: iniciando (brutos={usar_brutos})...")

    total_validos   = 0
    total_ignorados = 0

    for nome_sessao in sessoes:
        caminho_sessao = os.path.join(caminho_base, nome_sessao)
        if not os.path.isdir(caminho_sessao):
            if verbose:
                print(f"AVISO: Sessão '{nome_sessao}' não encontrada.")
            continue
        if verbose:
            print(f"  Processando '{nome_sessao}'...")

        # [FIX-13] Lista via .hea — garante par completo .hea + .dat
        arquivos = sorted([
            os.path.join(caminho_sessao, f[:-4])
            for f in os.listdir(caminho_sessao)
            if f.endswith('.hea')
        ])

        for caminho in arquivos:
            nome_base = os.path.basename(caminho)

            label = extrair_label_do_nome(nome_base)
            if label is None or label not in LABELS_VALIDOS:
                total_ignorados += 1
                continue

            try:
                reg   = wfdb.rdrecord(caminho, warn_empty=True)
                p_sig = getattr(reg, 'p_signal', None)

                # Suporte a registros multi-segmento
                if p_sig is None:
                    e_sig = getattr(reg, 'e_p_signal', None)
                    if e_sig and isinstance(e_sig, list):
                        try:
                            p_sig = np.concatenate(e_sig, axis=0)
                        except Exception:
                            p_sig = None

                if p_sig is None or p_sig.ndim != 2 or p_sig.shape[0] < comp_seg:
                    continue

                # Seleciona canais EMG
                idx_validos = [i for i in idx_emg if i < p_sig.shape[1]]
                if not idx_validos:
                    continue

                emg_raw = p_sig[:, idx_validos].astype(np.float32)

                # Padding se canais faltantes
                if len(idx_validos) < len(idx_emg):
                    pad = np.zeros((emg_raw.shape[0],
                                    len(idx_emg) - len(idx_validos)),
                                   dtype=np.float32)
                    emg_raw = np.concatenate([emg_raw, pad], axis=1)

                # Substitui NaN/Inf
                if not np.isfinite(emg_raw).all():
                    emg_raw = np.nan_to_num(emg_raw, nan=0.0,
                                            posinf=0.0, neginf=0.0)

                if usar_brutos:
                    emg = emg_raw
                else:
                    fs_real = getattr(reg, 'fs', FREQ_AMOSTRAGEM)
                    emg = preprocessar(emg_raw, fs_real=fs_real)

                n_segs = emg.shape[0] // comp_seg
                for i in range(n_segs):
                    s = i * comp_seg
                    total_validos += 1
                    if verbose and total_validos % 5000 == 0:
                        print(f"    ... {total_validos} segmentos gerados")
                    yield emg[s:s + comp_seg].astype(np.float32), np.int32(label)

            except Exception as exc:
                if verbose:
                    import traceback
                    print(f"    ERRO [{nome_base}]: {type(exc).__name__}: {exc}")
                    traceback.print_exc()
            finally:
                gc.collect()

    if verbose:
        print(f"INFO Gerador: {total_validos} segmentos produzidos "
              f"({total_ignorados} arquivos ignorados).")
    if total_validos == 0 and verbose:
        print("ERRO CRÍTICO: Nenhum segmento válido.")

