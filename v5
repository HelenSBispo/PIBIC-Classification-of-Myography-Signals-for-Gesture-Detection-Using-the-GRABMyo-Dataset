def para_treino(seg, rot):
    cod = lookup.lookup(tf.cast(rot, tf.int64))
    return seg, tf.one_hot(cod, NUM_CLASSES, dtype=tf.float32)

def para_metricas(seg, rot):
    cod = lookup.lookup(tf.cast(rot, tf.int64))
    return seg, tf.cast(cod, tf.int32)

dataset_teste_metrics = (
    dataset_teste_raw
    .map(para_metricas, num_parallel_calls=tf.data.AUTOTUNE)
    .batch(32)
    .prefetch(tf.data.AUTOTUNE)
)


def criar_datasets_com_batch(batch_size):
    """
    [FIX-4]  Recria datasets com o batch_size correto.
    [FIX-12] .repeat() + steps calculados para evitar esgotamento do gerador.
    """
    steps_treino = max(1, n_treino // batch_size)
    steps_val    = max(1, n_teste  // batch_size)

    ds_treino = (
        dataset_treino_raw
        .map(para_treino, num_parallel_calls=tf.data.AUTOTUNE)
        .batch(batch_size)
        .repeat()              # [FIX-12]
        .prefetch(tf.data.AUTOTUNE)
    )
    ds_val = (
        dataset_teste_raw
        .map(para_treino, num_parallel_calls=tf.data.AUTOTUNE)
        .batch(batch_size)
        .repeat()              # [FIX-12]
        .prefetch(tf.data.AUTOTUNE)
    )
    return ds_treino, ds_val, steps_treino, steps_val


