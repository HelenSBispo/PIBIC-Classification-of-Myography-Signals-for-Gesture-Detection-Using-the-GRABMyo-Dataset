def criar_modelo(
    filtros_conv1=64,
    kernel_size_conv1=9,
    activation='relu',
    dropout_rate=0.3,
    input_shape=(COMPRIMENTO_SEGMENTO, NUM_CANAIS_EMG),
    num_classes=NUM_CLASSES,
    optimizer_name='AdamW',
    learning_rate=LEARNING_RATE_FIXO,
    dense_units=DENSE_UNITS_FIXO,
):
    """
    Arquitetura 1D CNN — Figura 1 e Tabela 4 (SBCAS 2026).  [FIX-14]

    INPUT             : (1024, 14)
    Feature Block 1   : Conv1D(f, kernel_size) + BN + Act
    Feature Block 2   : Conv1D(f, 3)           + BN + Act
    Dimensionality Red: MaxPooling1D(2)
    Regularization    : Dropout(rate)
    [Iterative blocks — dashed box na Figura 1; aqui 1 iteração]
    GlobalAvgPool
    Dense(256) + BN + Act + Dropout
    Softmax(NUM_CLASSES)   ← 7 neurônios, alinhado com Figura 1

    Com filtros=64, kernel=9, dense=256, num_classes=17:
      Conv1D(64,9) : 14×9×64           =  8.064  + 256 BN  =  8.320
      Conv1D(64,3) : 64×3×64           = 12.288  + 256 BN  = 12.544
      GlobalAvgPool→ Dense(256): 64×256 = 16.384  + 1024 BN = 17.408
      Dense(17)    : 256×17 + 17       =  4.369
      Total                            ≈ 42.641  (próximo de 40.455)
    Nota: artigo reporta 40.455 com 7 classes; com 17 sobe ~2k — esperado.
    """
    ent = layers.Input(shape=input_shape, name='Entrada_EMG')
    x   = ent

    # Feature Extraction Block 1 — Figura 1
    x = layers.Conv1D(filtros_conv1, kernel_size_conv1,
                      padding='same', use_bias=False, name='Conv1')(x)
    x = layers.BatchNormalization(name='BN1')(x)
    x = layers.Activation(activation, name='Act1')(x)

    # Feature Extraction Block 2 — Figura 1
    x = layers.Conv1D(filtros_conv1, 3,
                      padding='same', use_bias=False, name='Conv2')(x)
    x = layers.BatchNormalization(name='BN2')(x)
    x = layers.Activation(activation, name='Act2')(x)

    # Dimensionality Reduction — Figura 1
    x = layers.MaxPooling1D(2, name='MaxPool')(x)

    # Regularization — Figura 1
    x = layers.Dropout(dropout_rate, name='Dropout')(x)

    # Global Average Pooling — Figura 1
    x = layers.GlobalAveragePooling1D(name='GlobalAvgPool')(x)

    # Fully Connected Stage — Figura 1: Dense(256) + BN + ReLU + Dropout
    x = layers.Dense(dense_units, use_bias=False, name='Dense1')(x)
    x = layers.BatchNormalization(name='BN_Dense')(x)
    x = layers.Activation(activation, name='Act_Dense')(x)
    x = layers.Dropout(dropout_rate, name='Drop_Dense')(x)

    # Softmax Classifier — Figura 1: "Dense Layer (7 neurons)"
    saida = layers.Dense(num_classes, activation='softmax', name='Saida')(x)

    modelo = models.Model(inputs=ent, outputs=saida, name='CNN_EMG_SBCAS2026')
    opt_cls = DICIONARIO_OTIMIZADORES.get(optimizer_name, optimizers.AdamW)
    modelo.compile(
        optimizer=opt_cls(learning_rate=learning_rate),
        loss='categorical_crossentropy',
        metrics=['accuracy'],
    )
    return modelo


